# ─────────────────────────────────────────────
#  Scrappy — Client Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# API base URL
# Local dev: leave empty (Vite proxy handles /api → localhost:3001)
VITE_API_URL=

# Production: point to your deployed backend
# Render example:
# VITE_API_URL=https://scrappy-api.onrender.com
#
# Fly.io example:
# VITE_API_URL=https://scrappy-api.fly.dev
#
# Koyeb example:
# VITE_API_URL=https://scrappy-api-yourname.koyeb.app

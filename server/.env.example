# ─────────────────────────────────────────────
#  Scrappy — Server Environment Variables
#  Copy this to .env and fill in values
# ─────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# Auth secret — any string works locally, use a long random one in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production

# Admin account (auto-created on first boot if it doesn't exist)
ADMIN_EMAIL=admin@scrappy.io
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=admin

# Frontend URL for CORS (comma-separated if multiple)
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────
#
#  LOCAL DEV — leave DATABASE_URL empty
#  Server automatically uses SQLite (scrappy.db). Zero config.
#
#  DATABASE_URL=
#
#  PRODUCTION (Render / any host) — paste Neon connection string
#  1. neon.tech → create free project → copy connection string
#  2. Paste below
#
#  DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/scrappy?sslmode=require
#
DATABASE_URL=
